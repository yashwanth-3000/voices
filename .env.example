# Shared 0G Galileo network
PRIVATE_KEY=
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
CHAINSCAN_API_KEY=placeholder

# 0G Storage
OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
OG_STORAGE_ENCRYPTION_KEY=
OG_STORAGE_KV_RPC=
AGENT_STORAGE_CACHE_PATH=.voices-storage-cache.json
# Demo mode should flush LangGraph checkpoints into 0G Storage so /proof/:requestId can show durable checkpoint evidence.
# Set to "memory" during local-only iteration if you want to avoid 0G write costs.
AGENT_CHECKPOINT_FLUSH_MODE=0g
AGENT_RUNTIME_KEY=

# 0G Compute for LangGraph upload/style-analysis agents.
# Mode: "0g" = real 0G broker/direct; "mock" = local deterministic mock
AGENT_COMPUTE_MODE=0g

# CrewAI chatbot generation can use ChatGPT/OpenAI without moving LangGraph upload agents off 0G.
CREWAI_COMPUTE_MODE=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium

# Option A: 0G broker (decentralised, TEE-verified) — leave API key empty
OG_COMPUTE_PROVIDER_ADDRESS=

# Option B: Direct API for highest-quality models — set all three values
# gpt-4o (OpenAI):       SERVICE_URL=https://api.openai.com/v1   MODEL=gpt-4o
# Claude Opus 4.7:       SERVICE_URL=https://api.anthropic.com/v1 MODEL=claude-opus-4-7
# Claude Sonnet 4.6:     SERVICE_URL=https://api.anthropic.com/v1 MODEL=claude-sonnet-4-6
OG_COMPUTE_SERVICE_URL=
OG_COMPUTE_MODEL=
OG_COMPUTE_API_KEY=
# Optional: route style extraction, generation, and platform tuning to your best available model.
# Leave empty to use OG_COMPUTE_MODEL or the 0G broker-advertised model.
OG_COMPUTE_GENERATION_MODEL=
OG_COMPUTE_GENERATION_TEMPERATURE=0.7
OG_COMPUTE_GENERATION_TOP_P=0.95

# Deployed contracts, filled by contracts/scripts/deploy.ts
STYLE_REGISTRY_ADDRESS=
ROYALTY_VAULT_ADDRESS=
CREDIT_SYSTEM_ADDRESS=
AGENT_STORAGE_MODE=0g
AGENT_CHAIN_MODE=0g
# Use "live" or "0g" to let 0G Compute choose LangGraph tools. Use "deterministic" for lower-cost local iteration.
AGENT_LANGGRAPH_PLANNER_MODE=live
# Chatbot generation runs through the Python CrewAI swarm.
# Use CREWAI_RUNTIME_MODE=bridge for local debugging without importing CrewAI.
CREWAI_PYTHON_BIN=python3
CREWAI_RUNTIME_MODE=auto
CREWAI_RUNNER_TIMEOUT_MS=180000
CREWAI_MAX_REVISIONS=1
# Keep Distribution Manager settlement-only by default so it does not flatten the Content Creator voice.
# Set to "live" only when you want an extra 0G Compute platform-rewrite pass.
AGENT_DISTRIBUTION_COMPUTE_TUNING=off

# Upload imports
# Used by frontend/app/api/import/blog to scrape blog/article URLs.
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
BRAINROT_FIRECRAWL_API_KEY=
BRAINROT_FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Optional import helpers
GITHUB_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_BEARER_TOKEN=
TWITTER_BEARER_TOKEN=
