{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mock": "PORT=4317 AGENT_STORAGE_MODE=memory AGENT_COMPUTE_MODE=mock AGENT_CHAIN_MODE=mock tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:mock": "PORT=4317 AGENT_STORAGE_MODE=memory AGENT_COMPUTE_MODE=mock AGENT_CHAIN_MODE=mock tsx src/index.ts",
    "start:0g": "AGENT_STORAGE_MODE=0g AGENT_COMPUTE_MODE=0g AGENT_CHAIN_MODE=0g tsx src/index.ts",
    "smoke:agents": "AGENT_STORAGE_MODE=memory AGENT_COMPUTE_MODE=mock AGENT_CHAIN_MODE=mock tsx src/smoke-agents.ts",
    "storage:hello": "tsx src/storage-hello.ts",
    "compute:hello": "tsx src/compute-hello.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@0glabs/0g-serving-broker": "^0.7.5",
    "@langchain/core": "^1.1.41",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint": "^1.0.1",
    "@langchain/langgraph-swarm": "^1.0.1",
    "@langchain/openai": "^1.4.4",
    "@langgraphjs/toolkit": "^1.2.9",
    "dotenv": "^17.2.3",
    "ethers": "6.13.1",
    "fastify": "^5.6.2",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@langchain/langgraph-checkpoint-validation": "^1.0.9",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
